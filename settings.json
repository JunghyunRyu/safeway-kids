{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "default",
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(npm test *)",
      "Bash(pnpm test *)",
      "Bash(yarn test *)",
      "Bash(pytest *)",
      "Bash(bash ${CLAUDE_PLUGIN_ROOT}/scripts/doctor.sh *)",
      "Bash(sh ${CLAUDE_PLUGIN_ROOT}/scripts/doctor.sh *)",
      "Bash(${CLAUDE_PLUGIN_ROOT}/scripts/doctor.sh *)",
      "Bash(bash ${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap-check.sh *)",
      "Bash(sh ${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap-check.sh *)",
      "Bash(${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap-check.sh *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)"
    ]
  }
}
